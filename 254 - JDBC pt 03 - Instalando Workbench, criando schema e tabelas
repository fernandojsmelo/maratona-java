CREATE TABLE `anime` (
	`id` INT(11) NOT NULL AUTO_INCREMENT,
	`name` VARCHAR(300) NOT NULL COLLATE 'utf8mb4_general_ci',
	`episodes` VARCHAR(255) NOT NULL COLLATE 'utf8mb4_general_ci',
	`producer_id` INT(11) NOT NULL,
	PRIMARY KEY (`id`) USING BTREE,
	INDEX `produce_id_idx` (`producer_id`) USING BTREE,
	CONSTRAINT `produce_id` FOREIGN KEY (`producer_id`) REFERENCES `producer` (`id`) ON UPDATE NO ACTION ON DELETE NO ACTION
)
COLLATE='utf8mb4_general_ci'
ENGINE=InnoDB

CREATE TABLE `producer` (
	`id` INT(11) NOT NULL AUTO_INCREMENT,
	`name` VARCHAR(255) NOT NULL COLLATE 'utf8mb4_general_ci',
	PRIMARY KEY (`id`) USING BTREE
)
COLLATE='utf8mb4_general_ci'
ENGINE=InnoDB
